pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                // Assuming the code is checked out via SCM
                echo 'Checking out code...'
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('playwright tests') {
                    bat 'npm install'
                }
            }
        }

        stage('Run Sample Tests') {
            steps {
                dir('playwright tests') {
                    bat 'npx playwright test tests/sampletests.spec.ts'
                }
            }
        }

        // stage('Publish Reports') {
        //     steps {
        //         dir('playwright tests') {
        //             publishHTML(target: [
        //                 allowMissing: false,
        //                 alwaysLinkToLastBuild: true,
        //                 keepAll: true,
        //                 reportDir: 'playwright-report',
        //                 reportFiles: 'index.html',
        //                 reportName: 'Playwright Sample Test Report'
        //             ])
        //         }
        //     }
        // }
    }

    post {
        always {
            echo 'Pipeline completed.'
        }
        failure {
            echo 'Pipeline failed.'
        }
    }
}